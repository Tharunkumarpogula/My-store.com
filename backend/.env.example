# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mywebsite
DB_DIALECT=postgres

# SQLite (instant local mode)
# Set DB_DIALECT=sqlite to run without installing Postgres/Docker.
# DB_DIALECT=sqlite
# DB_SQLITE_STORAGE=./dev.sqlite
